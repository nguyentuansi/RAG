# ─────────────────────────────────────────────
# RAG Platform Environment Configuration
# Copy to .env and fill in real values
# ─────────────────────────────────────────────

# ── Application ───────────────────────────────
ENVIRONMENT=development           # development | staging | production
DEBUG=false
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR

# ── API Server ────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_KEY_HEADER=X-API-Key
CORS_ORIGINS=http://localhost:3000,http://localhost:8501
MAX_UPLOAD_SIZE_MB=50

# ── JWT Authentication ────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-256-bit-random-key-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Qdrant Vector Store ───────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=                   # Leave blank for local/unauthenticated
QDRANT_PREFER_GRPC=true
COLLECTION_NAME=rag_documents

# ── Redis Cache ───────────────────────────────
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600
CACHE_MAX_CONNECTIONS=20

# ── Embeddings ────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2
# Options:
#   sentence-transformers/all-mpnet-base-v2  (768d, balanced)
#   sentence-transformers/all-MiniLM-L6-v2  (384d, fast)
#   BAAI/bge-base-en-v1.5                   (768d, high accuracy)
#   BAAI/bge-m3                             (1024d, multilingual)
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DEVICE=cpu              # cpu | cuda | mps

# ── Chunking Defaults ─────────────────────────
DEFAULT_CHUNK_SIZE=512
DEFAULT_CHUNK_OVERLAP=100

# ── Rate Limiting ─────────────────────────────
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10

# ── Observability ─────────────────────────────
OTLP_ENDPOINT=                    # http://otel-collector:4317 (leave blank to disable)
PROMETHEUS_ENABLED=true
METRICS_PORT=9090

# ── Database (audit logs) ─────────────────────
DATABASE_URL=sqlite+aiosqlite:///./rag.db
# For PostgreSQL: postgresql+asyncpg://user:pass@localhost:5432/ragdb
